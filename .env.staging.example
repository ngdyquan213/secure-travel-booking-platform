APP_NAME=Secure Travel Booking Platform
ENVIRONMENT=staging
DEBUG=false

SECRET_KEY=staging-secret-key-12345678901234567890
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

POSTGRES_USER=staging_user
POSTGRES_PASSWORD=staging-db-password-123456
POSTGRES_DB=secure_travel_booking_staging
DATABASE_URL=postgresql+psycopg2://staging_user:staging-db-password-123456@postgres:5432/secure_travel_booking_staging
PAYMENT_CALLBACK_SECRET=staging-payment-secret-123456

REDIS_URL=redis://redis:6379/0
HOST_HTTP_PORT=8080

RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_REGISTER_PER_MINUTE=5
RATE_LIMIT_REFRESH_PER_MINUTE=20
RATE_LIMIT_UPLOAD_PER_MINUTE=20
RATE_LIMIT_PAYMENT_CALLBACK_PER_MINUTE=50
RATE_LIMIT_DEFAULT_PER_MINUTE=120

ALLOWED_UPLOAD_EXTENSIONS=.pdf,.png,.jpg,.jpeg
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/png,image/jpeg

CORS_ORIGINS=https://staging.example.com
TRUSTED_HOSTS=staging.example.com,localhost,127.0.0.1

STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_BYTES=10485760
ALLOW_PAYMENT_SIMULATION=false
