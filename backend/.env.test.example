APP_NAME=Secure Travel Booking Platform
ENVIRONMENT=test
DEBUG=false

SECRET_KEY=test-secret-key-123456789012345678901234
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/secure_travel_booking_test
PAYMENT_CALLBACK_SECRET=test-payment-secret-123456

REDIS_URL=redis://localhost:6379/1
HOST_TEST_POSTGRES_PORT=5433
PAYMENT_CALLBACK_SOURCE_ALLOWLIST=127.0.0.1/32

RATE_LIMIT_ENABLED=false
RATE_LIMIT_LOGIN_PER_MINUTE=1000
RATE_LIMIT_REGISTER_PER_MINUTE=1000
RATE_LIMIT_REFRESH_PER_MINUTE=1000
RATE_LIMIT_UPLOAD_PER_MINUTE=1000
RATE_LIMIT_PAYMENT_CALLBACK_PER_MINUTE=1000
RATE_LIMIT_DEFAULT_PER_MINUTE=1000

CORS_ORIGINS=http://localhost,http://127.0.0.1
TRUSTED_HOSTS=localhost,127.0.0.1,testserver

STORAGE_BACKEND=local
LOCAL_STORAGE_BUCKET=local
LOCAL_UPLOAD_DIR=uploads_test
MAX_UPLOAD_SIZE_BYTES=10485760
OUTBOX_PROCESSING_BATCH_SIZE=20
OUTBOX_LEASE_SECONDS=5
OUTBOX_HEALTH_MODE=best_effort
RUNTIME_MAINTENANCE_INTERVAL_SECONDS=5
EMAIL_WORKER_BACKEND=mock
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=10
NOTIFICATION_WORKER_BACKEND=mock
NOTIFICATION_REDIS_CHANNEL=secure_travel.notifications.test
FORWARDED_ALLOW_IPS=127.0.0.1/32,10.0.0.0/8
S3_BUCKET_NAME=
S3_REGION=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
ALLOW_PAYMENT_SIMULATION=true
